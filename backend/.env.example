# ====================================
# TDJAASA BOT - ENVIRONMENT VARIABLES
# ====================================

# JWT Secret (IMPORTANT: Changer en production!)
JWT_SECRET=tdjaasa-super-secret-change-in-production

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Paystack Configuration (https://dashboard.paystack.com)
# Test keys (pour dev)
PAYSTACK_SECRET_KEY=sk_test_xxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxx

# Paystack Plan Codes (Create these in Paystack Dashboard > Recurring > Plans)
PAYSTACK_PLAN_STARTER=PLN_starter_code
PAYSTACK_PLAN_PRO=PLN_pro_code
PAYSTACK_PLAN_BUSINESS=PLN_business_code

# WhatsApp Cloud API (Optional - si vous utilisez l'API officielle)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_token_here
PHONE_NUMBER_ID=your_phone_number_id_here

# Resend (emails transactionnels — https://resend.com)
RESEND_API_KEY=re_your_api_key_here
# Adresse d'envoi — DOIT utiliser un domaine vérifié sur Resend. Sans ça, le
# fallback onboarding@resend.dev ne délivre QUE vers le compte Resend propriétaire.
RESEND_FROM=DjassaBot <no-reply@votre-domaine.com>

# Server Configuration
PORT=3000

# Environnement : "production" sur le VPS (active les logs JSON, désactive
# les endpoints de debug comme /api/debug/seed). Laisser vide en local.
NODE_ENV=production

# CORS : origines autorisées séparées par des virgules (en plus de *.vercel.app,
# *.nip.io et localhost qui sont déjà tolérés par défaut dans index.ts)
ALLOWED_ORIGINS=https://djassabot-saas.vercel.app

# Production URLs
FRONTEND_URL=https://djassabot-saas.vercel.app
API_URL=https://djassabot-saas-production.up.railway.app
